# SciSkills environment configuration
# Copy this file to .env and fill in your values

# ── Required: LLM API ──────────────────────────────────────────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1   # or any OpenAI-compatible endpoint
LLM_MODEL=gpt-4o                          # or claude-opus-4-6, doubao-seed-1.8, etc.

# ── OpenAI ─────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── Anthropic (via OpenAI-compatible proxy) ────────────────────────
# LLM_BASE_URL=https://api.anthropic.com/openai/v1
# LLM_MODEL=claude-opus-4-6

# ── Doubao (国内推荐) ───────────────────────────────────────────────
# LLM_BASE_URL=https://ep-llm.zhenguanyu.com/gateway-cn-online/openai-compatible/v1
# LLM_MODEL=doubao-seed-1.8

# ── Optional: Semantic Scholar API (higher rate limits) ───────────
# SEMANTIC_SCHOLAR_API_KEY=your_s2_key

# ── Optional: GROBID server (higher quality PDF parsing) ──────────
# GROBID_URL=http://localhost:8070
