# SciSkills environment configuration
# Copy this file to .env and fill in your values

# ── Required: LLM API ──────────────────────────────────────────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ep-llm.zhenguanyu.com/gateway-cn-online/openai-compatible/v1
LLM_MODEL=doubao-seed-1.8

# ── Optional: Use OpenAI directly ─────────────────────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── Optional: Use Anthropic Claude ────────────────────────────────
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-opus-4-6

# ── Optional: Semantic Scholar API (for higher rate limits) ───────
# SEMANTIC_SCHOLAR_API_KEY=your_s2_key

# ── Optional: GROBID server (for higher quality PDF parsing) ──────
# GROBID_URL=http://localhost:8070
